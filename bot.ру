from telegram import Update, ReplyKeyboardMarkup, KeyboardButton
from telegram.ext import ApplicationBuilder, CommandHandler, MessageHandler, ContextTypes, filters, ConversationHandler

TOKEN = "8286111048:AAG9uVFDL7tNOO_sWdesIGp2_ptCXJWwF-I"
ADMIN_ID = 6693304389

NAME, PHONE = range(2)

main_keyboard = ReplyKeyboardMarkup(
    [
        ["🚗 Услуги"],
        ["📝 Оставить заявку"],
        ["⭐ Отзывы"],
        ["📞 Связаться"]
    ],
    resize_keyboard=True
)

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text(
        "Здравствуйте! Вас приветствует бот EG Broker.\n\n"
        "Поможем с растаможкой автомобиля и оформлением документов.",
        reply_markup=main_keyboard
    )

async def services(update: Update, context: ContextTypes.DEFAULT_TYPE):
    text = (
        "Наши услуги:\n\n"
        "• Растаможка автомобилей\n"
        "• Оформление документов\n"
        "• Консультации по ввозу авто\n"
        "• Сопровождение сделки"
    )
    await update.message.reply_text(text)

async def reviews(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text(
        "Отзывы клиентов:\n"
        "https://t.me/ССЫЛКА_НА_КАНАЛ"
    )

async def contact(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text(
        "Связаться с нами:\n\n"
        "Телефон: +7 XXX XXX XX XX\n"
        "Telegram: @username"
    )

async def start_request(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text("Введите ваше имя:")
    return NAME

async def get_name(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data["name"] = update.message.text
    button = [[KeyboardButton("Отправить номер", request_contact=True)]]

    await update.message.reply_text(
        "Отправьте ваш номер телефона:",
        reply_markup=ReplyKeyboardMarkup(button, resize_keyboard=True, one_time_keyboard=True)
    )
    return PHONE

async def get_phone(update: Update, context: ContextTypes.DEFAULT_TYPE):
    phone = update.message.contact.phone_number
    name = context.user_data["name"]

    text = f"Новая заявка!\n\nИмя: {name}\nТелефон: {phone}"

    await context.bot.send_message(chat_id=ADMIN_ID, text=text)

    await update.message.reply_text(
        "Спасибо! Ваша заявка отправлена. Мы свяжемся с вами.",
        reply_markup=main_keyboard
    )

    return ConversationHandler.END


def main():

    app = ApplicationBuilder().token(TOKEN).build()

    conv_handler = ConversationHandler(
        entry_points=[MessageHandler(filters.Regex("📝 Оставить заявку"), start_request)],
        states={
            NAME: [MessageHandler(filters.TEXT & ~filters.COMMAND, get_name)],
            PHONE: [MessageHandler(filters.CONTACT, get_phone)]
        },
        fallbacks=[]
    )

    app.add_handler(CommandHandler("start", start))
    app.add_handler(MessageHandler(filters.Regex("🚗 Услуги"), services))
    app.add_handler(MessageHandler(filters.Regex("⭐ Отзывы"), reviews))
    app.add_handler(MessageHandler(filters.Regex("📞 Связаться"), contact))
    app.add_handler(conv_handler)

    print("Bot started...")
    app.run_polling()


if __name__ == "__main__":
    main()
